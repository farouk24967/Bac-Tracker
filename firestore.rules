rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "bouayedfarouk63@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================
    
    function isValidUser(data) {
      return data.get('uid', '') == request.auth.uid
        && data.get('displayName', '') is string && data.displayName.size() <= 200
        && data.get('email', '') is string
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 1000000))
        && (data.get('stream', null) == null || data.stream is string)
        && data.get('points', 0) is number
        && data.get('badges', []) is list
        && data.get('onboardingCompleted', false) is bool
        && data.get('currentStreak', 0) is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Prevent role escalation if role existed
        (!('role' in existing()) || incoming().get('role', '') == existing().role)
        || isAdmin()
      );
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid && isValidId(taskId);
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /subjectProgress/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid;
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /studyGoals/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /scheduledSessions/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /studySessions/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && existing().uid == request.auth.uid && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /activityLog/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
    }
  }
}
